		"lint:fix": "eslint . --fix",
		"format": "prettier . --write",
		"format:check": "prettier . --check"
	},
	"keywords": [],
	"author": "LucasOe",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@obsidian-typings/obsidian-public-latest": "^6.22.0",
		"@types/node": "^26.1.1",
		"@typescript-eslint/eslint-plugin": "^8.63.0",
		"@typescript-eslint/parser": "^8.63.0",
		"esbuild": "^0.28.1",
		"eslint": "^10.7.0",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"globals": "^17.7.0",
		"jiti": "^2.7.0",
		"obsidian": "latest",
		"prettier": "^3.9.5",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0"
	},
	"dependencies": {
		"monkey-around": "^3.0.0"
