{
	"name": "template-folder",
	"version": "1.0.4",
	"description": "Moves notes to a folder when applying a template.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
